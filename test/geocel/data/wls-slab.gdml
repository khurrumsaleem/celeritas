    <matrix name="WLSABS1" coldim="2" values="5.0e-6 100000000 7.0e-6 10 8.0e-6 1 9.0e-6 0.2 9.5e-6 0.1 10.0e-6 0.05 1.1e-5 0.05"/>
    <matrix name="WLSC1" coldim="2" values="2.6e-6 0.05 2.7e-6 0.15 2.8e-6 0.35 2.9e-6 0.80 3.0e-6 1.00 3.1e-6 0.80 3.2e-6 0.35 3.3e-6 0.15 3.4e-6 0.05"/>
    <matrix name="WLSMNP1" coldim="1" values="1.0"/>
