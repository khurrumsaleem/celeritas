    <matrix name="WLSC2" coldim="2" values="2.3e-6 0.05 2.4e-6 0.15 2.5e-6 0.40 2.6e-6 0.85 2.7e-6 1.00 2.8e-6 0.85 2.9e-6 0.40 3.0e-6 0.15 3.1e-6 0.05"/>
    <matrix name="WLSMNP2" coldim="1" values="0.9"/>
    <matrix name="WLSTC2" coldim="1" values="2.5"/>
